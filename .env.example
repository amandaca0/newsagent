ANTHROPIC_API_KEY=
NEWSAPI_KEY=
GROQ_API_KEY=

AGENT_PROVIDER=auto

# BlueBubbles — local two-way iMessage. Install the server from bluebubbles.app.
BLUEBUBBLES_SERVER_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

NEWSAGENT_DB_PATH=./data/newsagent.db
NEWSAGENT_CHROMA_PATH=./data/chroma
NEWSAGENT_PUBLIC_URL=http://localhost:5000

LLM_MODEL=llama-3.3-70b-versatile
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_JUDGE_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

PROACTIVE_PUSH_HOUR=8
MAX_ARTICLES_PER_PUSH=3

EVAL_MODE=1
